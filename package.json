{
  "name": "nfa-to-regex-converter",
  "private": true,
  "version": "1.0.0",
  "homepage": "https://harshpatel-21.github.io/nfa-regex",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@xyflow/react": "^12.10.0",
    "framer-motion": "^12.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^3.2.4",
    "gh-pages": "^6.3.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "test": {
    "environment": "jsdom",
    "setupFiles": [
      "./src/test/setup.ts"
    ],
    "globals": true,
    "coverage": {
      "provider": "v8",
      "reporter": [
        "text",
        "html"
      ],
      "include": [
        "src/**/*.{ts,tsx}"
      ],
      "exclude": [
        "src/test/**",
        "src/main.tsx"
      ]
    }
  }
}
